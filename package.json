{
  "name": "evaluation-viewer",
  "version": "0.1.0",
  "private": true,
  "description": "Diagnosis table share viewer built with React and Electron",
  "author": "Yusuke Miyauchi",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"node ./scripts/launch-electron-dev.mjs\"",
    "icons:generate": "bash ./scripts/generate-icons.sh",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --mac",
    "dist:arm64": "npm run build && electron-builder --mac --arm64",
    "dist:x64": "npm run build && electron-builder --mac --x64",
    "dist:dir": "npm run build && electron-builder --mac dir"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  },
  "build": {
    "appId": "com.evaluationviewer.app",
    "productName": "Diagnosis Share Viewer",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  }
}
